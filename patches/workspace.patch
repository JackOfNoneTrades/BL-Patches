index 0000000000000000000000000000000000000000..a913ad97b4680857897947a662a59d8bdd762c7c
--- /dev/null
+++ workspace/java/thebetweenlands/client/render/shader/FullscreenQuadHelper.java
@@ -0,0 +1,94 @@
+package thebetweenlands.client.render.shader;
+
+import java.lang.reflect.Method;
+
+import org.lwjgl.opengl.GL11;
+
+public final class FullscreenQuadHelper {
+	private static final String POST_PROCESSING_HELPER = "com.gtnewhorizon.gtnhlib.client.renderer.postprocessing.PostProcessingHelper";
+
+	private static Method bindFullscreenVAO;
+	private static Method drawFullscreenQuad;
+	private static Method unbindVAO;
+	private static boolean helperResolved;
+	private static boolean helperAvailable;
+
+	private FullscreenQuadHelper() {
+	}
+
+	public static boolean bind() {
+		if(!resolveHelper()) {
+			return false;
+		}
+		try {
+			bindFullscreenVAO.invoke(null);
+			return true;
+		} catch(Exception ex) {
+			disableHelper(ex);
+			return false;
+		}
+	}
+
+	public static void draw() {
+		if(helperAvailable) {
+			try {
+				drawFullscreenQuad.invoke(null);
+				return;
+			} catch(Exception ex) {
+				disableHelper(ex);
+			}
+		}
+		drawLegacy();
+	}
+
+	public static void unbind() {
+		if(!helperAvailable) {
+			return;
+		}
+		try {
+			unbindVAO.invoke(null);
+		} catch(Exception ex) {
+			disableHelper(ex);
+		}
+	}
+
+	private static boolean resolveHelper() {
+		if(helperResolved) {
+			return helperAvailable;
+		}
+
+		helperResolved = true;
+		try {
+			Class<?> helperClass = Class.forName(POST_PROCESSING_HELPER);
+			bindFullscreenVAO = helperClass.getMethod("bindFullscreenVAO");
+			drawFullscreenQuad = helperClass.getMethod("drawFullscreenQuad");
+			unbindVAO = helperClass.getMethod("unbindVAO");
+			helperAvailable = true;
+		} catch(Exception ex) {
+			helperAvailable = false;
+		}
+		return helperAvailable;
+	}
+
+	private static void disableHelper(Exception ex) {
+		helperAvailable = false;
+		System.err.println("Disabling GTNHLib fullscreen quad helper: " + ex.getMessage());
+	}
+
+	private static void drawLegacy() {
+		GL11.glBegin(GL11.GL_TRIANGLES);
+		GL11.glTexCoord2f(0.0F, 1.0F);
+		GL11.glVertex2f(-1.0F, -1.0F);
+		GL11.glTexCoord2f(0.0F, 0.0F);
+		GL11.glVertex2f(-1.0F, 1.0F);
+		GL11.glTexCoord2f(1.0F, 0.0F);
+		GL11.glVertex2f(1.0F, 1.0F);
+		GL11.glTexCoord2f(1.0F, 0.0F);
+		GL11.glVertex2f(1.0F, 1.0F);
+		GL11.glTexCoord2f(1.0F, 1.0F);
+		GL11.glVertex2f(1.0F, -1.0F);
+		GL11.glTexCoord2f(0.0F, 1.0F);
+		GL11.glVertex2f(-1.0F, -1.0F);
+		GL11.glEnd();
+	}
+}
