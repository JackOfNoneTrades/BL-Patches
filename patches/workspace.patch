@@ -0,0 +1,32 @@
+package thebetweenlands.client.render.shader;
+
+import org.lwjgl.opengl.GL11;
+
+import net.minecraft.client.renderer.OpenGlHelper;
+
+/**
+ * Keeps legacy fixed-function rendering on the default texture unit.
+ *
+ * Angelica's shader pipeline may leave auxiliary texture units active between
+ * passes, while old Betweenlands rendering code assumes that GL texture calls
+ * always operate on unit 0 like vanilla does.
+ */
+public final class TextureUnitHelper {
+	private static final int FIXED_FUNCTION_TEXTURE_UNITS = 4;
+
+	private TextureUnitHelper() {
+	}
+
+	public static void activateDefaultTextureUnit() {
+		OpenGlHelper.setActiveTexture(OpenGlHelper.defaultTexUnit);
+	}
+
+	public static void clearAuxiliaryTextureUnits() {
+		for(int unit = FIXED_FUNCTION_TEXTURE_UNITS - 1; unit >= 1; unit--) {
+			OpenGlHelper.setActiveTexture(OpenGlHelper.defaultTexUnit + unit);
+			GL11.glBindTexture(GL11.GL_TEXTURE_2D, 0);
+			GL11.glDisable(GL11.GL_TEXTURE_2D);
+		}
+		activateDefaultTextureUnit();
+	}
+}
